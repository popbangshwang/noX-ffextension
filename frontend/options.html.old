<!DOCTYPE html>
<html>
  <head>
    <title>noX-ffextension Options</title>
    <style>
      body { font-family: sans-serif; margin: 20px; max-width: 500px; }
      input { margin-bottom: 8px; }
      ul { padding-left: 20px; }
      button { margin-left: 5px; padding: 6px 12px; border-radius: 4px; cursor: pointer; }
      .section { margin-top: 24px; padding: 16px; border-left: 4px solid #ccc; background: #f9f9f9; border-radius: 4px; }
      img { border-radius: 4px; }
      .small-text { font-size: small; color: #666; margin-top: 8px; }
      .toggle-container { margin-bottom: 16px; }
      .toggle-label { display: flex; align-items: center; gap: 10px; }
      .toggle-label input[type="checkbox"] { width: 20px; height: 20px; cursor: pointer; }
      
      /* Color coding for sections */
      .whitelist-section { border-left-color: #6c5ce7; }
      .words-section { border-left-color: #00b894; }
      .faces-section { border-left-color: #e17055; }
      .display-section { border-left-color: #0984e3; }
      
      /* Button styling */
      button {
        background: #0984e3;
        color: white;
        border: none;
        transition: background 0.2s;
      }
      button:hover { background: #0770d2; }
      
      /* Toggle styling */
      .toggle-label input[type="checkbox"]:checked + span h2 {
        color: inherit;
      }

      @media (prefers-color-scheme: dark) {
        body {
          background: #181a1b;
          color: #eee;
        }
        input, button {
          background: #222;
          color: #eee;
          border: 1px solid #444;
        }
        .section {
          background: #1f1f1f;
        }
        button {
          background: #0984e3;
        }
        button:hover { background: #0770d2; }
        h2 { color: #fff; }
      }
    </style>
  </head>
<body>
  <div style="margin-bottom: 30px; border-bottom: 2px solid #0984e3; padding-bottom: 16px;">
    <h1 style="margin: 0 0 8px 0;">noX-ffextension Settings</h1>
    <p style="color: #666; margin: 0;">Customize how the extension blocks content</p>
  </div>

  <div id="saveNotification" style="display: none; background: #00b894; color: white; padding: 12px; border-radius: 4px; margin-bottom: 16px;">
    ✓ Settings saved!
  </div>

  <div class="section whitelist-section">
    <h2>URL Whitelist</h2>
    <p>Sites where the extension will not run. Enter one domain per line.</p>
    <textarea id="whitelistedUrls" placeholder="twitch.tv&#10;youtube.com&#10;example.com" rows="6"></textarea>
    <button id="saveWhitelist">Save Whitelist</button>
  </div>

  <div class="section words-section">
    <div class="toggle-container">
      <label class="toggle-label">
        <input id="blockedWordsToggle" type="checkbox" checked />
        <span>
          <h2 style="display: inline; margin: 0;">Blocked Words</h2>
          <span id="wordCount" style="color: #666; font-size: 0.9em; margin-left: 8px;"></span>
        </span>
      </label>
      <p class="small-text">Blocks text and images containing these words.</p>
    </div>
    <div style="display: flex; gap: 8px; margin-bottom: 12px;">
      <input id="wordInput" placeholder="Add word...(trump)" style="flex: 1;" />
      <button id="addBtn">Add Word</button>
    </div>
    <ul id="wordList"></ul>
  </div>

  <div class="section faces-section">
    <div class="toggle-container">
      <label class="toggle-label">
        <input id="blockedFacesToggle" type="checkbox" checked />
        <span>
          <h2 style="display: inline; margin: 0;">Blocked Faces</h2>
          <span id="faceCount" style="color: #666; font-size: 0.9em; margin-left: 8px;"></span>
        </span>
      </label>
      <p class="small-text">Uses facial recognition to block images of specific people.</p>
    </div>
    
    <div style="margin-bottom: 16px;">
      <label for="personName">Person Name:</label>
      <input id="personName" placeholder="e.g., trump" style="width: 100%; margin-top: 4px;" />
    </div>

    <div style="margin-bottom: 16px;">
      <label for="faceImage">Upload Images:</label>
      <input id="faceImage" type="file" accept="image/*" multiple style="margin-top: 4px;" />
      <p class="small-text">
        Upload 3-5 clear images per person from different angles.<br>
        Minimum: 120x120 pixels
      </p>
    </div>

    <button id="addFaceBtn" style="margin-bottom: 16px;">Add Person</button>
    <ul id="faceList"></ul>
    
    <hr style="margin: 20px 0; border: none; border-top: 1px solid #ddd;">
    
    <label for="similarityThreshold">Face Similarity Threshold:</label>
    <div style="display: flex; gap: 12px; align-items: center; margin-top: 8px;">
      <input 
        id="similarityThreshold" 
        type="range" 
        min="0.5" 
        max="1" 
        step="0.05" 
        value="0.8" 
        style="flex: 1;"
      />
      <span id="thresholdValue" style="min-width: 50px; font-weight: bold;">0.80</span>
    </div>
    <p class="small-text">
      <strong>Higher (0.9-1.0):</strong> Stricter matching, fewer false positives<br>
      <strong>Lower (0.5-0.7):</strong> Looser matching, catches more
    </p>
  </div>

  <div class="section display-section">
    <h2>Display Settings</h2>
    <label for="blurAmount">Blur Amount:</label>
    <div style="display: flex; gap: 12px; align-items: center; margin-top: 8px;">
      <input type="range" id="blurAmount" min="1" max="100" step="1" value="20" style="flex: 1;">
      <span id="blurValue" style="min-width: 50px; font-weight: bold;">20</span>px
    </div>
    <p class="small-text">Higher = more blur, lower = less blur. (1-100 pixels)</p>
  </div>

  <div style="margin-top: 30px; padding-top: 16px; border-top: 1px solid #ddd; text-align: center;">
    <button id="resetBtn" style="background: #e17055;">Reset All Settings to Defaults</button>
  </div>

    <script src="/libs/face-api.min.js"></script>
    <script src="options_modules.js"></script>
    <script src="options_blockedWords.js"></script>
    <script src="options_faces.js"></script>
    <script src="options_settings.js"></script>
    <script src="options_whitelist.js"></script>
    <script src="options_display.js"></script>
    <script src="options_reset.js"></script>
  </body>
</html>
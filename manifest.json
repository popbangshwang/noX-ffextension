{
  "manifest_version": 2,
  "name": "noX-ffextension",
  "version": "1.0",
  "description": "Blocks user-specified words and, in future, faces/images related to those words.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html"
  }
}
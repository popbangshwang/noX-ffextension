{
  "manifest_version": 2,
  "name": "noX-ffextension",
  "version": "1.0",
  "description": "Blocks user-specified words and faces/images related to those words.",
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["modules/url_filter.js", "modules/blocked_words.js", "modules/observer.js", "content.js"]
    }
  ],
  "background": {
    "scripts": ["load-mediapipe.js", "background.js"]
  },
  "browser_action": {
    "default_popup": "/frontend/popup.html",
    "default_title": "noX-ffextension"
  },
  "options_ui": {
    "page": "frontend/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    "modules/blocked_faces.js",
    "modules/overrides/youtube-override.js",
    "mediapipe-loader.js",
    "frontend/js/options-mediapipe-loader.js"
  ],
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval' https://cdn.jsdelivr.net https://storage.googleapis.com; object-src 'self'",
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
{
  "manifest_version": 2,
  "name": "noX-ffextension",
  "version": "1.0",
  "description": "Blocks user-specified words and faces/images related to those words.",
  "permissions": [
    "storage",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["libs/face-api.min.js", "background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    "models/ssd_mobilenetv1/*",
    "models/face_landmark_68/*",
    "models/face_recognition/*"
  ]
}